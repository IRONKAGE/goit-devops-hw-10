# ==========================================
# 1. СЕКРЕТИ ТА КОНФІГУРАЦІЇ (КРИТИЧНО!)
# ==========================================
# Ніколи не комітимо паролі та ключі доступу
.env
*.env
.env.local
.env.*.local

# ==========================================
# 2. PYTHON ТА DJANGO
# ==========================================
# Кеш байт-коду Python
__pycache__/
*.py[cod]
*$py.class

# Локальні бази даних (якщо ви тестуєте без Docker)
*.sqlite3
*.sqlite3-journal

# Статика та медіа (Збираються автоматично через entrypoint.sh)
staticfiles/
media/
public/static/

# ==========================================
# 3. ВІРТУАЛЬНІ СЕРЕДОВИЩА (VENV)
# ==========================================
# Наша папка з ізольованим Python (важить багато, генерується локально)
ml_venv/
venv/
env/
.venv/

# ==========================================
# 4. ЛОГИ ПРОЄКТУ ТА ПРОВІЖИНЕРІВ
# ==========================================
*.log
# Логи наших IaC скриптів
setup_linux.log
setup_macos_legacy.log
setup_server.log
setup_wsl1_bridge.log
setup_modern.log

# ==========================================
# 5. ІНФРАСТРУКТУРА (TERRAFORM ТА TERRAGRUNT)
# ==========================================
# Локальні директорії плагінів
.terraform/
**/.terraform/*

# Кеш Terragrunt (важить дуже багато)
.terragrunt-cache/
**/.terragrunt-cache/*

# Файли стейту (Якщо тестуємо локально без S3)
*.tfstate
*.tfstate.*

# Файли-перехоплювачі LocalStack Pro (КРИТИЧНО НЕ КОМІТИТИ!)
localstack_providers_override.tf

# LocalStack Pro persistent data (Бази даних, стейт хмари локально)
volume_89/

# Краш-логи
crash.log
crash.*.log

# ==========================================
# 6. ІНФРАСТРУКТУРА (DIRENV, NIX, ANSIBLE)
# ==========================================
# Локальні кеші direnv та nix
.direnv/
.envrc.cache
result

# Кеші Ansible
*.retry

# ==========================================
# 7. IDE ТА ОПЕРАЦІЙНІ СИСТЕМИ
# ==========================================
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Редактори коду (VS Code, PyCharm, тощо)
.vscode/
.idea/
*.swp
*.swo

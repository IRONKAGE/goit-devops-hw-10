# ==============================================================================
# MLOps Enterprise EditorConfig
# Гарантує єдиний стиль коду для команди (VS Code, PyCharm, Neovim тощо).
# ==============================================================================

# Це кореневий файл (IDE не повинна шукати інші конфіги вище по дереву папок)
root = true

# ------------------------------------------------------------------------------
# БАЗОВІ ПРАВИЛА ДЛЯ ВСІХ ФАЙЛІВ
# ------------------------------------------------------------------------------
[*]
charset = utf-8
# Завжди додавати порожній рядок в кінці файлу (стандарт POSIX)
insert_final_newline = true
# Автоматично видаляти зайві пробіли в кінці рядків (щоб Git diff був чистим)
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# 🔥 КРИТИЧНО ДЛЯ DOCKER: Завжди використовувати Linux-переноси рядків (LF).
# Якщо Windows-розробник збереже файл з CRLF, контейнер впаде.
end_of_line = lf

# ------------------------------------------------------------------------------
# PYTHON (Django & ML Models)
# ------------------------------------------------------------------------------
[*.py]
indent_style = space
indent_size = 4
# Максимальна довжина рядка (стандарт PEP8 - 88 або 119 для Django)
max_line_length = 119

# ------------------------------------------------------------------------------
# ІНФРАСТРУКТУРА ТА КОНФІГИ (Docker, YAML, JSON)
# ------------------------------------------------------------------------------
[*.{yml,yaml,json}]
indent_style = space
indent_size = 2

[Dockerfile*]
indent_style = space
indent_size = 4

# ------------------------------------------------------------------------------
# HCL (Terraform / Terragrunt)
# ------------------------------------------------------------------------------
[*.{tf,tfvars,hcl}]
# HashiCorp стандарт - 2 пробіли
indent_style = space
indent_size = 2

# ------------------------------------------------------------------------------
# СКРИПТИ BASH / ZSH (Linux/Mac пускачі)
# ------------------------------------------------------------------------------
[*.sh]
indent_style = space
indent_size = 4
# Жорстко фіксуємо LF для Bash-скриптів, інакше вони не запустяться в Docker
end_of_line = lf

# ------------------------------------------------------------------------------
# СКРИПТИ WINDOWS (Cmd, PowerShell)
# ------------------------------------------------------------------------------
[*.{cmd,bat}]
# Для старих Windows-скриптів безпечніше використовувати рідний формат CRLF
end_of_line = crlf
indent_style = space
indent_size = 4

[*.ps1]
# Сучасний PowerShell чудово розуміє LF
end_of_line = lf
indent_style = space
indent_size = 4

# ------------------------------------------------------------------------------
# ФРОНТЕНД / ВЕБ (Якщо з'являться шаблони HTML, CSS, JS)
# ------------------------------------------------------------------------------
[*.{html,css,js,ts}]
indent_style = space
indent_size = 2

# ------------------------------------------------------------------------------
# MAKEFILES
# ------------------------------------------------------------------------------
[Makefile]
# Makefiles вимагають ВИКЛЮЧНО таби. Пробіли їх зламають.
indent_style = tab
